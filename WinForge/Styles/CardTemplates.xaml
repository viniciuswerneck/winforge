    <!-- Package card with Atualizar button + available version (Atualizações tab) -->
    <DataTemplate x:Key="UpgradeCardTemplate">
        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderThickness="1"
                BorderBrush="{DynamicResource CardBorderBrush}"
                CornerRadius="10"
                Padding="16,14"
                Margin="0,0,0,10"
                Effect="{DynamicResource CardShadow}">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                            <Setter Property="Opacity" Value="0.6" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="36" Height="36"
                        CornerRadius="9"
                        VerticalAlignment="Center">
                    <Border.Background>
                        <SolidColorBrush Color="{Binding InitialColor, FallbackValue={StaticResource AccentGreen}}" />
                    </Border.Background>
                    <TextBlock Text="{Binding Initial}"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}"
                               FontSize="13.5"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Id}"
                               FontSize="10.5"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,2,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Border Style="{StaticResource TagPill}">
                            <TextBlock Text="{Binding Version, StringFormat='v{0}'}"
                                       FontSize="10.5"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Border>
                        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource SystemFillColorSuccessBrush}"
                                CornerRadius="5"
                                Padding="6,3"
                                Margin="6,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="→"
                                           FontSize="12"
                                           Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0" />
                                <TextBlock Text="{Binding AvailableVersion, StringFormat='v{0}'}"
                                           FontSize="10.5"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SystemFillColorSuccessBrush}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="Atualizar"
                        Style="{StaticResource ActionButton}"
                        Command="{Binding DataContext.UpgradePackageCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                        CommandParameter="{Binding}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                        Height="30"
                        VerticalAlignment="Center"
                        ToolTip="Atualizar este pacote" />
            </Grid>
        </Border>
    </DataTemplate>
</ResourceDictionary>
