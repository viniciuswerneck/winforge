<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Application Colors - Light Theme (Windows 11 premium) -->
    <Color x:Key="ApplicationBackgroundColor">#FFF0F0F0</Color>
    <Color x:Key="CardBackgroundColor">#FFFFFFFF</Color>
    <Color x:Key="ControlFillColorDefault">#FFFFFFFF</Color>
    <Color x:Key="ControlFillColorSecondary">#FFE8E8E8</Color>
    <Color x:Key="ControlFillColorTertiary">#FFD6D6D6</Color>
    <Color x:Key="ControlElevationBorder">#FFE0E0E0</Color>
    <Color x:Key="TextFillColorPrimary">#FF1A1A1A</Color>
    <Color x:Key="TextOnAccentFillColorPrimary">#FFFFFFFF</Color>
    <Color x:Key="AccentFillColorDefault">#FF005FB8</Color>
    <Color x:Key="AccentFillColorSecondary">#FF004C99</Color>
    <Color x:Key="AccentFillColorTertiary">#FF003A73</Color>
    <Color x:Key="SystemFillColorCritical">#FFC74242</Color>
    <Color x:Key="SystemFillColorSuccess">#FF2E8B57</Color>
    <Color x:Key="TextControlBackground">#FFFFFFFF</Color>
    <Color x:Key="TextFillColorSecondary">#FF777777</Color>
    <Color x:Key="TextFillColorTertiary">#FF999999</Color>
    <Color x:Key="CardBorderColor">#FFE8E8E8</Color>
    <Color x:Key="CardBorderHoverColor">#FFCCCCCC</Color>
    <Color x:Key="DividerColor">#FFE0E0E0</Color>
    <Color x:Key="TabIndicatorColor">#FF005FB8</Color>
    <Color x:Key="StatusSuccessColor">#FF2E8B57</Color>
    <Color x:Key="StatusWarningColor">#FFD09020</Color>
    <Color x:Key="StatusErrorColor">#FFC74242</Color>
    <Color x:Key="ScrollbarThumbColor">#FFC0C0C0</Color>
    <Color x:Key="ScrollbarThumbHoverColor">#FF999999</Color>
    <Color x:Key="ScrollbarTrackColor">#FFE8E8E8</Color>
    <Color x:Key="AccentBlue">#FF60B0FF</Color>
    <Color x:Key="AccentOrange">#FFF0A030</Color>
    <Color x:Key="AccentGreen">#FF4CCB70</Color>
    <Color x:Key="AccentPurple">#FFBE70FF</Color>
    <Color x:Key="AccentRed">#FFE04343</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="{StaticResource ApplicationBackgroundColor}" />
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="{StaticResource CardBackgroundColor}" />
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#FFE6E6E6" />
    <SolidColorBrush x:Key="HeaderForegroundBrush" Color="#FF1A1A1A" />
    <SolidColorBrush x:Key="HeaderAccentBrush" Color="#FF005FB8" />
    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{StaticResource ControlFillColorDefault}" />
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{StaticResource ControlFillColorSecondary}" />
    <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="{StaticResource ControlFillColorTertiary}" />
    <SolidColorBrush x:Key="ControlElevationBorderBrush" Color="{StaticResource ControlElevationBorder}" />
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource TextFillColorPrimary}" />
    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="{StaticResource TextOnAccentFillColorPrimary}" />
    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource AccentFillColorDefault}" />
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="{StaticResource AccentFillColorSecondary}" />
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="{StaticResource AccentFillColorTertiary}" />
    <SolidColorBrush x:Key="SystemFillColorCriticalBrush" Color="{StaticResource SystemFillColorCritical}" />
    <SolidColorBrush x:Key="SystemFillColorSuccessBrush" Color="{StaticResource SystemFillColorSuccess}" />
    <SolidColorBrush x:Key="TextControlBackgroundBrush" Color="{StaticResource TextControlBackground}" />
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource TextFillColorSecondary}" />
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{StaticResource TextFillColorTertiary}" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}" />
    <SolidColorBrush x:Key="CardBorderHoverBrush" Color="{StaticResource CardBorderHoverColor}" />
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}" />
    <SolidColorBrush x:Key="TabIndicatorBrush" Color="{StaticResource TabIndicatorColor}" />
    <SolidColorBrush x:Key="StatusSuccessBrush" Color="{StaticResource StatusSuccessColor}" />
    <SolidColorBrush x:Key="StatusWarningBrush" Color="{StaticResource StatusWarningColor}" />
    <SolidColorBrush x:Key="StatusErrorBrush" Color="{StaticResource StatusErrorColor}" />
    <SolidColorBrush x:Key="ScrollbarThumbBrush" Color="{StaticResource ScrollbarThumbColor}" />
    <SolidColorBrush x:Key="ScrollbarThumbHoverBrush" Color="{StaticResource ScrollbarThumbHoverColor}" />
    <SolidColorBrush x:Key="ScrollbarTrackBrush" Color="{StaticResource ScrollbarTrackColor}" />

    <!-- Card Shadow -->
    <DropShadowEffect x:Key="CardShadow"
                      BlurRadius="12"
                      Opacity="0.08"
                      ShadowDepth="3"
                      Direction="270"
                      Color="#000000" />

    <DropShadowEffect x:Key="CardShadowElevated"
                      BlurRadius="16"
                      Opacity="0.14"
                      ShadowDepth="4"
                      Direction="270"
                      Color="#000000" />
</ResourceDictionary>
