<Window x:Class="WinForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:WinForge.Converters"
        mc:Ignorable="d"
        Title="WinForge - Gerenciador de Pacotes"
        Icon="icon.ico"
        Height="760" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
        TextElement.FontSize="13"
        AllowsTransparency="False"
        UseLayoutRounding="True">

    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="F" Command="{Binding SearchPackagesCommand}" />
        <KeyBinding Modifiers="Control" Key="L" Command="{Binding LoadInstalledCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <ResourceDictionary>
            <conv:InverseBoolConverter x:Key="InverseBool" />
            <conv:StringNotEmptyToVisibilityConverter x:Key="StringNotEmpty" />
            <conv:IntToVisibilityConverter x:Key="IntToVis" />
            <BooleanToVisibilityConverter x:Key="BoolToVis" />

            <!-- ═══════ SCROLLBAR THUMB TEMPLATE ═══════ -->
            <ControlTemplate x:Key="ScrollBarThumbTemplate" TargetType="Thumb">
                <Border x:Name="ThumbBorder"
                        Background="{DynamicResource ScrollbarThumbBrush}"
                        CornerRadius="4"
                        Margin="1,1"
                        Opacity="0.6" />
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="ThumbBorder" Property="Background"
                                Value="{DynamicResource ScrollbarThumbHoverBrush}" />
                        <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.9" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <!-- ═══════ SCROLLBAR STYLE ═══════ -->
            <Style x:Key="ModernScrollBar" TargetType="ScrollBar">
                <Setter Property="Stylus.IsPressAndHoldEnabled" Value="False" />
                <Setter Property="Width" Value="8" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid>
                                <Border x:Name="TrackBackground"
                                        Background="{DynamicResource ScrollbarTrackBrush}"
                                        CornerRadius="4"
                                        Margin="1,0" />
                                <Track x:Name="PART_Track"
                                       IsDirectionReversed="False"
                                       ViewportSize="{TemplateBinding ViewportSize}">
                                    <Track.Thumb>
                                        <Thumb x:Name="Thumb"
                                               Focusable="False"
                                               BorderThickness="0"
                                               OverridesDefaultStyle="True"
                                               Template="{StaticResource ScrollBarThumbTemplate}" />
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="Orientation" Value="Horizontal">
                                    <Setter Property="Width" Value="Auto" />
                                    <Setter Property="Height" Value="8" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ScrollViewer">
                <Setter Property="OverridesDefaultStyle" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollViewer">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                        Grid.Row="0" Grid.Column="0"
                                                        CanContentScroll="{TemplateBinding CanContentScroll}"
                                                        CanHorizontallyScroll="False"
                                                        CanVerticallyScroll="False"
                                                        ContentTemplate="{TemplateBinding ContentTemplate}"
                                                        Content="{TemplateBinding Content}"
                                                        Margin="{TemplateBinding Padding}" />
                                <ScrollBar x:Name="PART_VerticalScrollBar"
                                           Grid.Row="0" Grid.Column="1"
                                           Style="{StaticResource ModernScrollBar}"
                                           AutomationProperties.AutomationId="VerticalScrollBar"
                                           Maximum="{TemplateBinding ScrollableHeight}"
                                           Minimum="0"
                                           Value="{Binding VerticalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                                           ViewportSize="{TemplateBinding ViewportHeight}"
                                           Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />
                                <ScrollBar x:Name="PART_HorizontalScrollBar"
                                           Grid.Row="1" Grid.Column="0"
                                           Orientation="Horizontal"
                                           Style="{StaticResource ModernScrollBar}"
                                           AutomationProperties.AutomationId="HorizontalScrollBar"
                                           Maximum="{TemplateBinding ScrollableWidth}"
                                           Minimum="0"
                                           Value="{Binding HorizontalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                                           ViewportSize="{TemplateBinding ViewportWidth}"
                                           Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}" />
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════ TAB STYLES ═══════ -->
            <Style x:Key="TabHeaderStyle" TargetType="TabItem">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Padding" Value="20,14" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="0"
                                    Padding="{TemplateBinding Padding}"
                                    Cursor="Hand">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="2" />
                                    </Grid.RowDefinitions>
                                    <ContentPresenter Grid.Row="0"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                    <Border Grid.Row="1"
                                            x:Name="Indicator"
                                            Height="2"
                                            CornerRadius="1"
                                            Background="Transparent"
                                            Margin="12,0" />
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Indicator" Property="Background"
                                            Value="{DynamicResource TabIndicatorBrush}" />
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background"
                                            Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="MainTabControlStyle" TargetType="TabControl">
                <Setter Property="Background" Value="{DynamicResource ApplicationBackgroundBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabControl">
                            <Grid KeyboardNavigation.TabNavigation="Local">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0"
                                        Background="{DynamicResource HeaderBackgroundBrush}"
                                        BorderThickness="0,0,0,1"
                                        BorderBrush="{DynamicResource DividerBrush}"
                                        Padding="0">
                                    <TabPanel x:Name="HeaderPanel"
                                              Panel.ZIndex="1"
                                              KeyboardNavigation.TabIndex="1"
                                              IsItemsHost="True"
                                              Margin="16,0" />
                                </Border>
                                <Border Grid.Row="1"
                                        Background="{TemplateBinding Background}"
                                        BorderThickness="0"
                                        KeyboardNavigation.TabNavigation="Local"
                                        KeyboardNavigation.DirectionalNavigation="Contained">
                                    <ContentPresenter x:Name="PART_SelectedContentHost"
                                                      ContentSource="SelectedContent"
                                                      Margin="{TemplateBinding Padding}" />
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════ CARD LIST STYLE ═══════ -->
            <Style x:Key="CardListStyle" TargetType="ListBox">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
                <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel" />
                <Setter Property="VirtualizingPanel.CacheLength" Value="20,20" />
                <Setter Property="ItemContainerStyle">
                    <Setter.Value>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.97" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.97" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════ BUTTON STYLES ═══════ -->
            <Style x:Key="ActionButton" TargetType="Button">
                <Setter Property="Padding" Value="16,7" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    BorderBrush="{TemplateBinding BorderBrush}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background"
                                            Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background"
                                            Value="{DynamicResource AccentFillColorTertiaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.35" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
                <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                <Setter Property="Padding" Value="14,6" />
                <Setter Property="FontSize" Value="11.5" />
            </Style>

            <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                <Setter Property="Padding" Value="12,6" />
                <Setter Property="FontSize" Value="11.5" />
            </Style>

            <Style x:Key="IconButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="Foreground" Value="{DynamicResource HeaderForegroundBrush}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background"
                                            Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background"
                                            Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════ TAG PILL ═══════ -->
            <Style x:Key="TagPill" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
                <Setter Property="CornerRadius" Value="5" />
                <Setter Property="Padding" Value="8,3" />
            </Style>

            <Style x:Key="TagPillAccent" TargetType="Border" BasedOn="{StaticResource TagPill}">
                <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                <Setter Property="Padding" Value="8,3" />
            </Style>

            <!-- ═══════ EMPTY STATE ═══════ -->
            <Style x:Key="EmptyState" TargetType="Border">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="Padding" Value="24" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <!-- ═══════ INSTALLED CARD TEMPLATE ═══════ -->
            <DataTemplate x:Key="InstalledCardTemplate">
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        CornerRadius="10"
                        Padding="16,14"
                        Margin="0,0,0,10"
                        Effect="{DynamicResource CardShadow}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Opacity" Value="0.6" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="9" VerticalAlignment="Center">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding InitialColor, FallbackValue={StaticResource AccentBlue}}" />
                            </Border.Background>
                            <TextBlock Text="{Binding Initial}" FontSize="15" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Id}" FontSize="10.5" Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Border Style="{StaticResource TagPill}">
                                    <TextBlock Text="{Binding Version, StringFormat='v{0}'}" FontSize="10.5" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </Border>
                                <Border Style="{StaticResource TagPill}" Background="{DynamicResource ControlFillColorSecondaryBrush}" Margin="6,0,0,0">
                                    <TextBlock Text="{Binding Source}" FontSize="10.5" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="2" Content="Desinstalar" Style="{StaticResource DangerButton}"
                                Command="{Binding DataContext.UninstallPackageCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                CommandParameter="{Binding}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                Height="30" VerticalAlignment="Center" ToolTip="Remover este pacote do sistema" />
                    </Grid>
                </Border>
            </DataTemplate>

            <!-- ═══════ SEARCH CARD TEMPLATE ═══════ -->
            <DataTemplate x:Key="SearchCardTemplate">
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        CornerRadius="10"
                        Padding="16,14"
                        Margin="0,0,0,10"
                        Effect="{DynamicResource CardShadow}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Opacity" Value="0.6" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="9" VerticalAlignment="Center">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding InitialColor, FallbackValue={StaticResource AccentOrange}}" />
                            </Border.Background>
                            <TextBlock Text="{Binding Initial}" FontSize="15" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Id}" FontSize="10.5" Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Border Style="{StaticResource TagPill}">
                                    <TextBlock Text="{Binding Version, StringFormat='v{0}'}" FontSize="10.5" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </Border>
                                <Border Style="{StaticResource TagPill}" Background="{DynamicResource ControlFillColorSecondaryBrush}" Margin="6,0,0,0">
                                    <TextBlock Text="{Binding Source}" FontSize="10.5" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="2" Content="Instalar" Style="{StaticResource ActionButton}"
                                Command="{Binding DataContext.InstallPackageCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                CommandParameter="{Binding}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                Height="30" VerticalAlignment="Center" ToolTip="Instalar este pacote" />
                    </Grid>
                </Border>
            </DataTemplate>

            <!-- ═══════ UPGRADE CARD TEMPLATE ═══════ -->
            <DataTemplate x:Key="UpgradeCardTemplate">
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        CornerRadius="10"
                        Padding="16,14"
                        Margin="0,0,0,10"
                        Effect="{DynamicResource CardShadow}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Opacity" Value="0.6" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="9" VerticalAlignment="Center">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding InitialColor, FallbackValue={StaticResource AccentGreen}}" />
                            </Border.Background>
                            <TextBlock Text="{Binding Initial}" FontSize="15" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Id}" FontSize="10.5" Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Border Style="{StaticResource TagPill}">
                                    <TextBlock Text="{Binding Version, StringFormat='v{0}'}" FontSize="10.5" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </Border>
                                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderThickness="1" BorderBrush="{DynamicResource SystemFillColorSuccessBrush}"
                                        CornerRadius="5" Padding="6,3" Margin="6,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="→" FontSize="12" Foreground="{DynamicResource SystemFillColorSuccessBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock Text="{Binding AvailableVersion, StringFormat='v{0}'}" FontSize="10.5" FontWeight="SemiBold" Foreground="{DynamicResource SystemFillColorSuccessBrush}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="2" Content="Atualizar" Style="{StaticResource ActionButton}"
                                Command="{Binding DataContext.UpgradePackageCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                CommandParameter="{Binding}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                Height="30" VerticalAlignment="Center" ToolTip="Atualizar este pacote" />
                    </Grid>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════ HEADER ═══════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource HeaderBackgroundBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource DividerBrush}"
                Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="26" Height="26"
                            CornerRadius="7"
                            Background="{DynamicResource HeaderAccentBrush}"
                            Margin="0,0,10,0">
                        <TextBlock Text="W"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="WinForge"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource HeaderForegroundBrush}" />
                    <TextBlock Text="Gerenciador de Pacotes"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Opacity="0.45"
                               Foreground="{DynamicResource HeaderForegroundBrush}"
                               Margin="10,0,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Command="{Binding LoadInstalledCommand}"
                            Style="{StaticResource IconButton}"
                            ToolTip="Recarregar"
                            Height="32" Width="32">
                        <TextBlock Text="↻" FontSize="15" />
                    </Button>
                    <Button Command="{Binding ToggleThemeCommand}"
                            Height="32" Width="32"
                            Margin="4,0,0,0"
                            ToolTip="Alternar tema">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <TextBlock Text="🌙" FontSize="15" />
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDarkTheme}" Value="False">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <TextBlock Text="☀️" FontSize="15" />
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════ TABS ═══════ -->
        <TabControl Grid.Row="1"
                    x:Name="MainTabControl"
                    Style="{StaticResource MainTabControlStyle}"
                    ItemContainerStyle="{StaticResource TabHeaderStyle}"
                    SelectedIndex="0">

            <!-- ═══ TAB 1: INSTALADOS ═══ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📦" FontSize="14" Margin="0,0,6,0" />
                        <TextBlock Text="Instalados" />
                    </StackPanel>
                </TabItem.Header>
                <Border Background="{DynamicResource ApplicationBackgroundBrush}">
                    <Grid Margin="24,20,24,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Pacotes Instalados"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <Border Grid.Column="2"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                    CornerRadius="8"
                                    Padding="2,2"
                                    Height="32"
                                    VerticalAlignment="Center">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="🔎"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               Margin="8,0,6,0"
                                               Opacity="0.4" />
                                    <TextBox Grid.Column="1"
                                             x:Name="InstalledFilterInput"
                                             Text="{Binding InstalledFilterQuery, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             FontSize="12"
                                             Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                             Padding="0,3"
                                             VerticalAlignment="Center"
                                             VerticalContentAlignment="Center" />
                                    <Button Grid.Column="2"
                                            FontSize="11"
                                            Width="22" Height="22"
                                            Margin="0,0,2,0"
                                            ToolTip="Limpar filtro"
                                            Visibility="{Binding InstalledFilterQuery, Converter={StaticResource StringNotEmpty}}"
                                            Command="{Binding ClearInstalledFilterCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                <Setter Property="Content" Value="✕" />
                                                <Setter Property="Opacity" Value="0.4" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.8" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Border>
                            <ComboBox Grid.Column="3"
                                      ItemsSource="{Binding SourceFilters}"
                                      SelectedItem="{Binding SelectedSourceFilter}"
                                      FontSize="11.5"
                                      Height="30"
                                      VerticalAlignment="Center"
                                      Margin="8,0,0,0"
                                      Padding="6,1"
                                      Background="{DynamicResource ControlFillColorDefaultBrush}"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      BorderBrush="{DynamicResource CardBorderBrush}"
                                      BorderThickness="1" />
                            <Border Grid.Column="4"
                                    Style="{StaticResource TagPill}"
                                    VerticalAlignment="Center"
                                    Margin="10,0,0,0">
                                <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="10.5">
                                    <Run Text="{Binding InstalledCount, FallbackValue=0}" />
                                    <Run Text="de" />
                                    <Run Text="{Binding TotalInstalledCount, FallbackValue=0}" />
                                    <Run Text="pacotes" />
                                </TextBlock>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="1">
                            <ListBox ItemsSource="{Binding InstalledPackages}"
                                     SelectedItem="{Binding SelectedInstalledPackage}"
                                     Style="{StaticResource CardListStyle}"
                                     Visibility="{Binding HasInstalledPackages, Converter={StaticResource BoolToVis}}">
                                <ListBox.ItemTemplate>
                                    <StaticResource ResourceKey="InstalledCardTemplate" />
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Empty: no packages at all -->
                            <Border Style="{StaticResource EmptyState}"
                                    Visibility="{Binding ShowInstalledEmpty, Converter={StaticResource BoolToVis}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="📦"
                                               FontSize="40"
                                               HorizontalAlignment="Center"
                                               Opacity="0.4" />
                                    <TextBlock Text="Nenhum pacote instalado"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,12,0,0" />
                                    <TextBlock Text="Use a aba Buscar &amp; Instalar para adicionar pacotes"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>

                            <!-- Empty: filter with no results -->
                            <Border Style="{StaticResource EmptyState}"
                                    Visibility="{Binding ShowInstalledNoResults, Converter={StaticResource BoolToVis}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="🔍"
                                               FontSize="40"
                                               HorizontalAlignment="Center"
                                               Opacity="0.3" />
                                    <TextBlock Text="Nenhum resultado encontrado"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,12,0,0" />
                                    <TextBlock Text="Tente alterar o termo da busca"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ═══ TAB 2: BUSCAR & INSTALAR ═══ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" FontSize="14" Margin="0,0,6,0" />
                        <TextBlock Text="Buscar &amp; Instalar" />
                    </StackPanel>
                </TabItem.Header>
                <Border Background="{DynamicResource ApplicationBackgroundBrush}">
                    <Grid Margin="24,20,24,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="4,4"
                                Margin="0,0,0,16">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=SearchInput, Path=IsKeyboardFocused}" Value="True">
                                            <Setter Property="BorderBrush"
                                                    Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="🔎"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               Margin="12,0,8,0"
                                               Opacity="0.4" />
                                    <TextBox x:Name="SearchInput"
                                             Grid.Column="1"
                                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             FontSize="13.5"
                                             Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                             Padding="4,7"
                                             VerticalAlignment="Center">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding SearchPackagesCommand}" />
                                        </TextBox.InputBindings>
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="TextBox">
                                                            <Grid>
                                                                <ScrollViewer x:Name="PART_ContentHost"
                                                                              Margin="{TemplateBinding Padding}"
                                                                              VerticalAlignment="Center" />
                                                                <TextBlock Text="Digite o nome do pacote..."
                                                                           FontSize="13.5"
                                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                           Opacity="0.5"
                                                                           IsHitTestVisible="False"
                                                                           Margin="{TemplateBinding Padding}"
                                                                           VerticalAlignment="Center"
                                                                           Visibility="Collapsed">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Text.Length, ElementName=SearchInput}" Value="0">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <Button Grid.Column="2"
                                            FontSize="12"
                                            Width="28" Height="28"
                                            Margin="0,0,4,0"
                                            ToolTip="Limpar"
                                            Visibility="{Binding SearchQuery, Converter={StaticResource StringNotEmpty}}"
                                            Command="{Binding ClearSearchCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                <Setter Property="Content" Value="✕" />
                                                <Setter Property="Opacity" Value="0.4" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.8" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1">
                            <ListBox ItemsSource="{Binding SearchResults}"
                                     SelectedItem="{Binding SelectedSearchResult}"
                                     Style="{StaticResource CardListStyle}"
                                     Visibility="{Binding HasSearchResults, Converter={StaticResource BoolToVis}}">
                                <ListBox.ItemTemplate>
                                    <StaticResource ResourceKey="SearchCardTemplate" />
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Empty: no search yet -->
                            <Border Style="{StaticResource EmptyState}"
                                    Visibility="{Binding HasNoSearchResults, Converter={StaticResource BoolToVis}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="🔍"
                                               FontSize="40"
                                               HorizontalAlignment="Center"
                                               Opacity="0.3" />
                                    <TextBlock Text="Busque por pacotes"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,12,0,0" />
                                    <TextBlock Text="Digite o nome do pacote para buscar"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>

                    </Grid>
                </Border>
            </TabItem>

            <!-- ═══ TAB 3: ATUALIZAÇÕES ═══ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⬆️" FontSize="14" Margin="0,0,6,0" />
                        <TextBlock Text="Atualizações" />
                        <Border x:Name="UpdateCountBadge"
                                Background="{DynamicResource SystemFillColorSuccessBrush}"
                                CornerRadius="8"
                                MinWidth="16" Height="16"
                                Margin="8,0,0,0"
                                Padding="4,0"
                                Visibility="{Binding UpdatesCount, Converter={StaticResource IntToVis}}">
                            <TextBlock Text="{Binding UpdatesCount}"
                                       FontSize="9"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </TabItem.Header>
                <Border Background="{DynamicResource ApplicationBackgroundBrush}">
                    <Grid Margin="24,20,24,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Atualizações Disponíveis"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <Button Grid.Column="2"
                                    Content="Atualizar Todos"
                                    Style="{StaticResource ActionButton}"
                                    Command="{Binding UpgradeAllCommand}"
                                    Height="34"
                                    Padding="18,6"
                                    FontSize="12" />
                        </Grid>

                        <Grid Grid.Row="1">
                            <ListBox ItemsSource="{Binding UpgradablePackages}"
                                     SelectedItem="{Binding SelectedUpgradablePackage}"
                                     Style="{StaticResource CardListStyle}"
                                     Visibility="{Binding HasUpdates, Converter={StaticResource BoolToVis}}">
                                <ListBox.ItemTemplate>
                                    <StaticResource ResourceKey="UpgradeCardTemplate" />
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Empty State -->
                            <Border Style="{StaticResource EmptyState}"
                                    Visibility="{Binding HasNoUpdates, Converter={StaticResource BoolToVis}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="⬆️"
                                               FontSize="40"
                                               HorizontalAlignment="Center"
                                               Opacity="0.3" />
                                    <TextBlock Text="Tudo atualizado!"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,12,0,0" />
                                    <TextBlock Text="Nenhuma atualização disponível no momento"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <!-- ═══════ STATUS BAR ═══════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource DividerBrush}"
                Padding="20,7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="6" Height="6"
                        CornerRadius="3"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource StatusSuccessBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource StatusWarningBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Style="{StaticResource TagPill}"
                            Margin="0,0,6,0">
                        <TextBlock Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   FontSize="10.5">
                            <Run Text="{Binding TotalInstalledCount, FallbackValue=0}" />
                            <Run Text="instalados" />
                        </TextBlock>
                    </Border>
                    <Border Style="{StaticResource TagPill}"
                            Margin="0,0,6,0">
                        <TextBlock Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   FontSize="10.5">
                            <Run Text="{Binding UpdatesCount, FallbackValue=0}" />
                            <Run Text="atualizações" />
                        </TextBlock>
                    </Border>

                    <Border Width="1" Height="14"
                            Background="{DynamicResource DividerBrush}"
                            Margin="6,0,10,0" />

                    <Border Style="{StaticResource TagPill}"
                            Margin="0,0,14,0">
                        <TextBlock Text="{Binding AppVersion}"
                                   FontSize="10.5"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    </Border>

                    <TextBlock FontSize="10.5"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                        <Hyperlink NavigateUri="https://lab.werneck.dev.br/"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                   TextDecorations="None">
                            Desenvolvido por Werneck Lab
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════ ONBOARDING OVERLAY ═══════ -->
        <Border Grid.Row="1" Grid.RowSpan="2"
                Background="#E0000000"
                Visibility="{Binding ShowOnboarding, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="10">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    CornerRadius="16"
                    Padding="36,32"
                    Width="440"
                    Effect="{DynamicResource CardShadowElevated}">
                <StackPanel>
                    <TextBlock Text="🔩"
                               FontSize="48"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Bem-vindo ao WinForge"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0" />
                    <TextBlock Text="Seu gerenciador de pacotes winget com interface gráfica moderna."
                               FontSize="12.5"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,8,0,0" />
                    <Border Height="1"
                            Background="{DynamicResource DividerBrush}"
                            Margin="0,20,0,16" />
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="📦" FontSize="16" Margin="0,0,10,0" />
                            <StackPanel>
                                <TextBlock Text="Gerencie pacotes instalados"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <TextBlock Text="Veja, busque e remova programas do seu sistema"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="🔍" FontSize="16" Margin="0,0,10,0" />
                            <StackPanel>
                                <TextBlock Text="Busca em tempo real"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <TextBlock Text="Encontre pacotes da comunidade winget e Microsoft Store"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="⬆️" FontSize="16" Margin="0,0,10,0" />
                            <StackPanel>
                                <TextBlock Text="Mantenha tudo atualizado"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <TextBlock Text="Veja e aplique atualizações de todos os seus aplicativos"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="Começar"
                            Style="{StaticResource ActionButton}"
                            Command="{Binding DismissOnboardingCommand}"
                            Height="38"
                            FontSize="13"
                            Margin="0,20,0,0"
                            HorizontalAlignment="Stretch" />
                </StackPanel>
            </Border>
        </Border>

        <!-- ═══════ BUSY OVERLAY ═══════ -->
        <Border Grid.Row="1" Grid.RowSpan="2"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                Opacity="0.88"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
                <Border Width="44" Height="44"
                        CornerRadius="12"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        HorizontalAlignment="Center">
                    <TextBlock Text="⚙️"
                               FontSize="20"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="Processando..."
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,12,0,0"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="11"
                           Margin="0,4,0,0"
                           Opacity="0.5"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           TextTrimming="CharacterEllipsis" />
                <ProgressBar Width="220"
                             Height="3"
                             Margin="0,16,0,0"
                             IsIndeterminate="True"
                             Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                             Background="{DynamicResource ControlFillColorDefaultBrush}"
                             BorderThickness="0"
                             HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
